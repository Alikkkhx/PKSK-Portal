rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Вспомогательная функция для проверки авторизации
    function isSignedIn() {
      return request.auth != null;
    }
    
    // Вспомогательная функция для получения данных текущего пользователя
    function getUserData() {
      // Ищем пользователя по UID (рекомендуется) или по номеру телефона
      // Для текущей структуры иерархия документов может быть сложной.
      // Предположим, мы храним UID в документе пользователя.
      return get(/databases/$(database)/documents/users/$(request.auth.token.email.split('@')[0])).data;
    }

    // --- ПОЛЬЗОВАТЕЛИ ---
    match /users/{phone} {
      // Разрешаем профиль только если номер совпадает с email Firebase Auth
      // Обычные пользователи могут получить только роль 'resident'
      allow create: if isSignedIn() 
                    && request.auth.token.email.split('@')[0] == phone
                    && (request.resource.data.role == 'resident' || (['7770001122', '77761193121'].propertyIsEnumerable(phone) || phone == '77761193121' || phone == '87761193121') && request.resource.data.role == 'admin');
                    
      // Разрешаем чтение своего профиля или админу
      allow get: if isSignedIn() && (request.auth.token.email.split('@')[0] == phone || getUserData().role == 'admin');
      allow list: if isSignedIn() && getUserData().role == 'admin';
    }
    
    // --- СООБЩЕНИЯ ---
    match /messages/{messageId} {
      // Разрешаем чтение, если пользователь состоит в этом ЖК или админ
      allow read: if isSignedIn() && (
        resource.data.buildingId == getUserData().buildingId || 
        getUserData().role == 'admin'
      );
      // Разрешаем писать сообщения в свой ЖК
      allow create: if isSignedIn() && (
        request.resource.data.buildingId == getUserData().buildingId || 
        getUserData().role == 'admin'
      );
      allow update, delete: if isSignedIn() && getUserData().role == 'admin';
    }
    
    // --- ЗАЯВКИ ---
    match /requests/{requestId} {
      allow read: if isSignedIn() && (
        resource.data.buildingId == getUserData().buildingId || 
        getUserData().role == 'admin'
      );
      allow create: if isSignedIn(); 
      allow update, delete: if isSignedIn() && getUserData().role == 'admin';
    }
    
    // --- ЗДАНИЯ ---
    match /buildings/{buildingId} {
      allow read: if true; // Нужно для регистрации
      allow write: if isSignedIn() && getUserData().role == 'admin';
    }
  }
}
