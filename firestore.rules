rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // --- Помощники ---
    function isSignedIn() { return request.auth != null; }
    function getUserData() { return get(/databases/$(database)/documents/users/$(request.auth.uid)).data; }
    
    // Проверка глобального админа (без привязки к ЖК)
    function isGlobalAdmin() { 
      let user = getUserData();
      return user.role in ['super_admin', 'admin'] && (user.buildingId == null || user.buildingId == '');
    }

    function isRole(role) { return getUserData().role == role; }
    function hasRole(roles) { return getUserData().role in roles; }
    function isSameBuilding(buildingId) { return getUserData().buildingId == buildingId; }

    // --- Пользователи ---
    match /users/{userId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn() && (request.auth.uid == userId || isRole('super_admin'));
    }

    // --- Чаты ---
    match /chats/{chatId} {
      allow read: if isSignedIn() && (
        request.auth.uid in resource.data.participants || 
        hasRole(['super_admin', 'admin']) ||
        (hasRole(['building_admin', 'operator']) && isSameBuilding(resource.data.buildingId))
      );
      allow create, update: if isSignedIn();
      
      match /messages/{messageId} {
        allow read: if isSignedIn(); 
        allow create: if isSignedIn() && (request.auth.uid == request.resource.data.senderId);
      }
    }

    match /user_chats/{userChatId} {
      allow read, write: if isSignedIn() && (
        request.auth.uid == resource.data.userId || 
        request.auth.uid == request.resource.data.userId ||
        hasRole(['super_admin', 'admin'])
      );
    }

    // --- Заявки ---
    match /requests/{requestId} {
      allow read: if isSignedIn() && (
        request.auth.uid == resource.data.residentUid || 
        isGlobalAdmin() ||
        (hasRole(['building_admin', 'operator', 'admin']) && isSameBuilding(resource.data.buildingId))
      );
      
      allow create: if isSignedIn();
      allow update: if isSignedIn() && (
        isGlobalAdmin() ||
        (hasRole(['building_admin', 'operator', 'admin']) && isSameBuilding(resource.data.buildingId))
      );
    }

    // --- Системные Логи ---
    match /system_logs/{logId} {
      allow create: if isSignedIn(); 
      // Разрешаем чтение всем администраторам для мониторинга
      allow read, list: if isSignedIn() && hasRole(['super_admin', 'admin']);
    }

    // --- Инфраструктура ---
    match /buildings/{buildingId} {
      allow read: if true; 
      allow write: if isSignedIn() && isRole('super_admin');
    }

    match /building_sites/{buildingId} {
      allow read: if true; 
      allow write: if isSignedIn() && (
        isRole('super_admin') || 
        (hasRole(['building_admin', 'admin']) && isSameBuilding(buildingId))
      );
    }
  }
}
