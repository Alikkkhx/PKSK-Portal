rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    match /uploads/{allPaths=**} {
      // Разрешаем чтение всем (для отображения в заявках)
      allow read: if true;
      // Разрешаем загрузку только авторизованным пользователям
      allow write: if request.auth != null;
    }
  }
}
